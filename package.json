{
  "name": "@awesomeniko/kafka-trail",
  "version": "0.2.3",
  "description": "A Node.js library for managing message queue with Kafka",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "Kafka",
    "Kafkajs",
    "Message queue",
    "Service",
    "Microservice",
    "Producer",
    "Consumer",
    "Typescript",
    "Nodejs"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "Nikolai Terskikh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AwesomeNiko/kafka-trail.git"
  },
  "scripts": {
    "lint": "yarn lint:check",
    "lint:check": "yarn typecheck && eslint --max-warnings 0 --format stylish \"./**/*.ts{,x}\"",
    "lint:fix": "eslint --fix --max-warnings 0 --format stylish \"./**/*.ts{,x}\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:native": "cd native/lz4 && napi build --release",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.unit.json --detectOpenHandles",
    "test:int": "node --env-file-if-exists=.env --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.int.json --detectOpenHandles",
    "test": "yarn test:unit && yarn test:int",
    "prepare": "husky",
    "start": "NODE_PATH=./dist node --enable-source-maps dist/test-run.js",
    "build": "yarn build:native && rimraf dist && tsc -P tsconfig.build.json",
    "dev": "npm run build && npm run start"
  },
  "dependencies": {
    "@aws-sdk/client-glue": "^3.1016.0",
    "@opentelemetry/api": "^1.9.0",
    "kafkajs": "^2.2.4",
    "pino": "^9.6.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2",
    "@jest/globals": "^30.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.13.4",
    "@typescript-eslint/eslint-plugin": "8.24.1",
    "@typescript-eslint/parser": "8.24.1",
    "ajv": "^8.18.0",
    "eslint": "9.20.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-import-resolver-typescript": "^3.5.3",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "husky": "^9",
    "jest": "^30.3.0",
    "minimatch": "3.1.3",
    "prettier": "^3.2.4",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.6",
    "typescript": "5.7.3",
    "zod": "^4.3.6"
  },
  "resolutions": {
    "**/flatted": "3.4.2",
    "**/js-yaml": "4.1.1"
  },
  "files": [
    "dist",
    "native/lz4",
    "LICENSE",
    "README.md"
  ]
}
